BINANCE_API_KEY=
BINANCE_API_SECRET=

# dry_run | testnet
TRADING_MODE=dry_run

SYMBOLS=BTCUSDT,ETHUSDT
SIGNAL_INTERVAL=15m
TREND_INTERVAL=1h
KLINE_LIMIT=500

RISK_PER_TRADE=0.0025
DAILY_LOSS_LIMIT=0.015
MAX_TRADES_PER_DAY=3
MAX_OPEN_POSITIONS=1
LEVERAGE=3
REWARD_RISK=1.8

EMA_FAST=20
EMA_SLOW=50
EMA_TREND=200
ATR_PERIOD=14
ATR_MIN_PCT=0.002
VOLUME_PERIOD=20
VOLUME_MULTIPLIER=1.15

POLL_SECONDS=30
LOG_LEVEL=INFO

# Веб-сервер (в Docker задаётся автоматически)
WEB_HOST=127.0.0.1
WEB_PORT=8000

# Жёсткая защита: true приводит к ошибке конфигурации.
# Live-режим отсутствует в этой версии.
ENABLE_LIVE_ORDERS=false
LIVE_CONFIRMATION=
